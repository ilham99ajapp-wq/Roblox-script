-- SCRIPT TRIAL (10 MENIT)
task.spawn(function()
    task.wait(600) -- 600 detik = 10 menit
    
    -- Menghapus GUI biar gak bisa dipake lagi
    local playerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    local gui = playerGui:FindFirstChild("CinematicPro_GodVersion")
    if gui then gui:Destroy() end
    
    -- Membalikan kamera ke normal biar dia gak nyangkut
    workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    
    -- Memunculkan notifikasi di layar HP dia kalau waktu habis
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Waktu Trial Habis!",
        Text = "Silakan bayar sisa 5k untuk versi Permanen.",
        Duration = 10
    })
end)

